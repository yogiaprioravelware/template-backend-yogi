{
  "name": "template-yogiravelware",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jest --testPathIgnorePatterns=tests/e2e",
    "test:coverage": "jest --coverage --testPathIgnorePatterns=tests/e2e",
    "test:e2e": "set NODE_ENV=test&& jest --config jest.e2e.config.js --runInBand",
    "test:postman": "npx newman run postman_collection_automation.json",
    "start": "node index.js",
    "dev": "nodemon index.js",
    "migrate:up": "sequelize-cli db:migrate",
    "migrate:down": "sequelize-cli db:migrate:undo",
    "seed:up": "sequelize-cli db:seed:all --seeders-path src/seeders",
    "seed:down": "sequelize-cli db:seed:undo:all --seeders-path src/seeders",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "tedious": "^19.2.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2"
  }
}
